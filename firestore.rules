rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isInternalAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'fernandook2016@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isInternalAdmin();
      allow list: if isInternalAdmin();
      allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['email', 'country', 'device', 'referralCode', 'createdAt', 'isAdmin']) &&
                      incoming().isAdmin == (request.auth.token.email == 'fernandook2016@gmail.com' && request.auth.token.email_verified == true) &&
                      incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'lastLoginAt', 'language']);
      allow update: if isInternalAdmin();
    }

    // Balances
    match /balances/{userId} {
      allow get: if isOwner(userId) || isInternalAdmin();
      allow create: if isOwner(userId) && 
                      incoming().current == 0 && 
                      incoming().totalEarned == 0 && 
                      incoming().offersCompleted == 0;
      allow update: if isInternalAdmin();
    }

    // Transactions
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isInternalAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isInternalAdmin());
      allow write: if isInternalAdmin();
    }

    // Withdrawals
    match /withdrawals/{withdrawalId} {
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().status == 'pending' &&
                      incoming().amount >= 5 &&
                      incoming().amount is number &&
                      incoming().details is string && incoming().details.size() <= 1000;
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isInternalAdmin());
      allow update: if isInternalAdmin();
    }

    // Referrals
    match /referrals/{referrerId} {
      allow read: if isOwner(referrerId) || isInternalAdmin();
      
      match /members/{memberId} {
        allow create: if isSignedIn() && 
                        request.auth.uid == memberId &&
                        incoming().joinedAt == request.time;
        allow read: if isOwner(referrerId) || isInternalAdmin();
      }
    }
    
    // Admins collection
    match /admins/{userId} {
      allow read: if isOwner(userId) || isInternalAdmin();
      allow create: if isOwner(userId) && 
                      request.auth.token.email == 'fernandook2016@gmail.com' && 
                      request.auth.token.email_verified == true;
    }
  }
}
